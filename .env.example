# Local-only configuration. .env is gitignored AND .cursorignored.
#
# Consumers:
#   - vitest                       (auto-loads .env at test startup)
#   - cdk.json -> "app"            (auto-loads via node --env-file-if-exists)
#   - scripts/provision-secrets.sh (reads tokens, pushes to SSM)
#
# NOTE on tokens: the deployed Lambda does NOT read tokens from this file -
# it reads them from SSM SecureString parameters (see config/app.config.ts
# -> ssm and AGENTS.md > SSM secrets). The entries below are used by
# `npm run secrets` to push values into SSM, and by anything you might run
# locally that talks to Telegram for real. SSM is always the source of
# truth for production; if you ever rotate at BotFather, update the value
# here and run `npm run secrets:rotate`.

# ---- Telegram (main bot) ----
BOT_TOKEN=

# ---- Telegram (logs bot for operator notifications) ----
LOGS_BOT_TOKEN=
LOGS_CHAT_ID=

# ---- Lambda runtime config (also baked in by CDK at deploy time) ----
USERS_TABLE_NAME=berlin-holidays-bot-users
LOG_LEVEL=info
