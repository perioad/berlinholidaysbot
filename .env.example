# Local-only configuration. .env is gitignored AND .cursorignored.
#
# Consumers:
#   - vitest                       (auto-loads .env at test startup)
#   - cdk.json -> "app"            (auto-loads via node --env-file-if-exists)
#   - scripts/provision-secrets.sh (reads tokens, pushes to SSM)
#
# IMPORTANT: the deployed Lambda does NOT read tokens from this file or
# from its own env vars - it fetches them from SSM SecureString parameters
# at cold start (see src/core/config/secrets.ts and AGENTS.md > SSM
# secrets). The entries below are used by `npm run secrets` to push values
# into SSM, and by anything you run locally that talks to Telegram for
# real. SSM is always the source of truth for production.

# ---- Telegram (main bot) ----
BOT_TOKEN=

# ---- Telegram (logs bot for operator notifications) ----
LOGS_BOT_TOKEN=
LOGS_CHAT_ID=

# ---- Non-secret runtime config (CDK puts these on the Lambda directly) ----
USERS_TABLE_NAME=berlin-holidays-bot-users
LOG_LEVEL=info
