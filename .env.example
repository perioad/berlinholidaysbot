# Telegram main bot
BOT_TOKEN=

# Logs bot (separate Telegram bot used to report errors)
LOGS_BOT_TOKEN=
LOGS_CHAT_ID=

# Optional shared secret Telegram sends in X-Telegram-Bot-Api-Secret-Token header
TELEGRAM_WEBHOOK_SECRET=

# Lambda runtime env vars (set automatically by CDK at deploy time;
# listed here for local development and tests)
USERS_TABLE_NAME=berlin-holidays-bot-users
LOG_LEVEL=info
